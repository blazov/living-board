# Supabase connection URL (public, used by the Next.js frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public API key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Secret used for signing auth tokens (generate with: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret

# AgentMail API key for thelivingboard@agentmail.to inbox
AGENTMAIL_API_KEY=your-agentmail-api-key
