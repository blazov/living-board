# Supabase connection URL (public, used by the Next.js frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public API key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# (Optional) Supabase Postgres connection URL — used by artifacts/scripts/scheduler-status.sh
# for the in-band heartbeat line printed by cycle-start.sh. Without it, every cycle logs
# "[scheduler] skipped: no SUPABASE_DB_URL" and the 6h-dropout WARN becomes unreachable.
# Copy from: Supabase Dashboard → Project Settings → Database → Connection string (URI).
# Use the "Transaction" or "Session" pooler string — the "psql" tab shows the right form.
SUPABASE_DB_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-region.pooler.supabase.com:6543/postgres

# Dashboard login password (generate with: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret

# (Optional) AgentMail API key — only needed if using AgentMail for email
AGENTMAIL_API_KEY=your-agentmail-api-key

# (Optional) Claude API key and trigger ID — only needed for the "Run Agent" button
CLAUDE_API_KEY=your-claude-api-key
TRIGGER_ID=your-trigger-id
